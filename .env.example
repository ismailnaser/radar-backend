# انسخ إلى .env وعدّل — لا ترفع .env إلى Git
# التطوير المحلي:
DEBUG=True
DJANGO_USE_SQLITE=1
SECRET_KEY=ضع-مفتاحاً-عشوائياً-طويلاً
# اتركها فارغة أو احذف السطر لاستخدام localhost و127.0.0.1 وtestserver
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# إذا كان Windows يعرّف DATABASE_URL من نشر سابق وتفشل الاتصالات محلياً:
# DJANGO_USE_SQLITE=1
# أو احذف/علّق DATABASE_URL من متغيرات النظام

# PostgreSQL (إنتاج / Render)
# DATABASE_URL=postgres://USER:PASS@HOST:PORT/db?sslmode=require

# CORS و CSRF للإنتاج فقط (مع DEBUG=False)
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
# CSRF_TRUSTED_ORIGINS=https://your-backend.onrender.com
